SQL> CREATE TABLE SU_CUSTOMER_WK (
  2  	    ZIP5		 VARCHAR2(5) NOT NULL
  3  					CONSTRAINT STRING_5_DIGITS409
  4  					       CHECK (rpad(translate(ZIP5,'01234567890','1111111111'),10,'1') = '1111111111'),
  5  	    SUMMARY_WEEK	 DATE NOT NULL
  6  					CONSTRAINT DAY_IS_SUN_MIDNIGHT243
  7  					       CHECK (SUMMARY_WEEK = TRUNC(SUMMARY_WEEK)
  8  						     AND
  9  						     To_Char(SUMMARY_WEEK,'DY') = 'SUN'),
 10  	    LOAN_TYPE		 VARCHAR2(40) NOT NULL
 11  					CONSTRAINT LOAN_TYPE_VALUES241
 12  					       CHECK (LOAN_TYPE IN ('REFI','FIRST','REPEAT')),
 13  	    EDUCATION		 VARCHAR2(40) NOT NULL
 14  					CONSTRAINT STRING_UCASE37821
 15  					       CHECK (EDUCATION = Upper(EDUCATION)),
 16  	    GENDER		 VARCHAR2(40) NOT NULL
 17  					CONSTRAINT STRING_UCASE37822
 18  					       CHECK (GENDER = Upper(GENDER)),
 19  	    AGE_BRACKET 	 NUMBER(3) NOT NULL
 20  					CONSTRAINT GTR_EQ_08833
 21  					       CHECK (AGE_BRACKET >= 0),
 22  	    HOUSEHOLD_SIZE	 NUMBER(3) NOT NULL
 23  					CONSTRAINT GTR_EQ_08834
 24  					       CHECK (HOUSEHOLD_SIZE >= 0),
 25  	    LOAN_BRACKET	 NUMBER(12,2) NOT NULL,
 26  	    CUSTOMER_TYPE	 VARCHAR2(40) NOT NULL
 27  					CONSTRAINT STRING_UCASE37823
 28  					       CHECK (CUSTOMER_TYPE = Upper(CUSTOMER_TYPE)),
 29  	    SUMMARY_MONTH	 DATE NOT NULL
 30  					CONSTRAINT DAY_IS_FST_MNTH245
 31  					       CHECK (SUMMARY_MONTH = TRUNC(SUMMARY_MONTH)
 32  						     AND
 33  						     To_Char(SUMMARY_MONTH,'DD') = '01'),
 34  	    HOW_MANY		 NUMBER NULL
 35  					CONSTRAINT GTR_EQ_08835
 36  					       CHECK (HOW_MANY >= 0),
 37  	    CONSTRAINT SUCW_INDEX0
 38  		   PRIMARY KEY (ZIP5, SUMMARY_WEEK, LOAN_TYPE, EDUCATION,
 39  		   GENDER, AGE_BRACKET, HOUSEHOLD_SIZE, LOAN_BRACKET,
 40  		   CUSTOMER_TYPE)
 41  	    USING INDEX
 42  		   TABLESPACE MU_SUMMARYIND
 43  )
